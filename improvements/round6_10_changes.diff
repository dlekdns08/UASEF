+# UASEF CI — pytest + import + smoke (audit 6.10)
+#
+# 트리거: push/PR. 외부 API 키가 필요한 통합 테스트는 unit suite에서 분리.
+name: Tests
+
+on:
+  push:
+    branches: [main]
+  pull_request:
+    branches: [main]
+
+jobs:
+  unit-tests:
+    runs-on: ubuntu-latest
+    strategy:
+      matrix:
+        python-version: ["3.11", "3.12"]
+    steps:
+      - uses: actions/checkout@v4
+
+      - name: Set up Python ${{ matrix.python-version }}
+        uses: actions/setup-python@v5
+        with:
+          python-version: ${{ matrix.python-version }}
+          cache: pip
+
+      - name: Install package + test deps
+        run: |
+          pip install --upgrade pip
+          pip install -e .
+          pip install pytest pytest-cov
+
+      - name: Smoke import check
+        run: |
+          python -c "
+          import sys; sys.path.insert(0, '.')
+          # 19+ 모듈 모두 import
+          from models.uqm import UQM, ScoringMethod, compute_hybrid_score
+          from models.rtc_ede import RTC, EDE, detect_no_evidence
+          from models.model_interface import backend_supports_logprobs
+          from models.hybrid_weight_search import grid_search_hybrid_weights
+          from experiments.metrics_utils import (
+              compute_binary_metrics, wilson_ci, bootstrap_ci, bonferroni_adjust,
+              holm_bonferroni, results_dir,
+          )
+          from experiments.config_utils import load_config, load_calibration_config, load_hybrid_weights
+          from experiments.config_schema import validate_config_dict
+          from experiments.run_all_experiments import build_summary, build_markdown_report
+          from experiments.compare_runs import build_comparison_table
+          print('All imports OK')
+          "
+
+      - name: Run pytest
+        env:
+          UASEF_ALLOW_FALLBACK: "1"   # CI에서는 fallback 데이터 허용
+        run: |
+          pytest tests/ -v --tb=short
+
+      - name: CLI --help check (audit 6.10)
+        run: |
+          python experiments/run_all_experiments.py --help > /dev/null
+          python experiments/run_baseline_comparison.py --help > /dev/null
+          python experiments/run_agent_experiment.py --help > /dev/null
+          python experiments/eval_medabstain.py --help > /dev/null
+          python experiments/pareto_sweep.py --help > /dev/null
+          python experiments/compare_runs.py --help > /dev/null
+
+  docker-build:
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v4
+      - name: Build Docker image
+        run: docker build -t uasef:ci .
+      - name: Verify image entrypoint
+        run: docker run --rm uasef:ci experiments/run_all_experiments.py --help
