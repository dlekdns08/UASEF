# ── OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini          # gpt-4o / gpt-4o-mini

# ── LMStudio ─────────────────────────────────────────────────────
# LMStudio → Local Server → Start Server (기본 포트: 1234)
LMSTUDIO_MODEL=meta-llama-3.1-8b-instruct
# 모델명은 LMStudio UI에서 로드된 모델명과 정확히 일치해야 합니다.
# 예: mistral-7b-instruct-v0.3, gemma-2-9b-it, qwen2.5-7b-instruct

# ── LangSmith 트레이싱 (선택) ─────────────────────────────────────
# https://smith.langchain.com 에서 API 키 발급
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_your-key-here
LANGCHAIN_PROJECT=UASEF-agent
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com  # 기본값, 변경 불필요